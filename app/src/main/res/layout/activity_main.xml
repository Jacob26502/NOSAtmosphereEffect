<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?attr/colorSurface"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <ImageView
            android:layout_width="96dp"
            android:layout_height="96dp"
            android:src="@drawable/ic_launcher_foreground"
            app:tint="@color/brand_primary"
            android:contentDescription="@string/app_logo_desc"
            android:layout_marginBottom="32dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/app_title"
            android:textAppearance="?attr/textAppearanceDisplayMedium"
            android:textColor="?attr/colorOnSurface"
            android:textAlignment="center"
            android:layout_marginBottom="12dp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/status_instruction"
            android:textAppearance="?attr/textAppearanceBodyLarge"
            android:textColor="@color/white"
            android:gravity="center"
            android:layout_marginBottom="48dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnMainAction"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="56dp"
            android:text="@string/action_select_effect"
            android:textSize="16sp"
            app:icon="@android:drawable/ic_menu_gallery"
            app:iconGravity="textStart"
            android:backgroundTint="@color/brand_primary"
            android:textColor="?attr/colorOnPrimary" />

        <LinearLayout
            android:id="@+id/layoutSettings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            android:background="@drawable/text_bg_scrim_rounded"
            android:padding="16dp"
            android:layout_marginBottom="24dp"
            android:layout_marginTop="24dp">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/black"
                app:strokeColor="@color/white_alpha_70"
                app:strokeWidth="1dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:id="@+id/textDimness"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/dimness_level"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:textStyle="bold"/>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderDimness"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0.0"
                        android:valueTo="0.8"
                        android:stepSize="0.05"
                        android:value="0.2"
                        android:layout_marginBottom="24dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUpdateDimness"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/update_wallpaper_dimness"
                        android:backgroundTint="@color/btn_update_selector"
                        android:textColor="@color/text_update_selector"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBlurSettings"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/black"
                app:strokeColor="@color/white_alpha_70"
                app:strokeWidth="1dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="0dp"
                android:layout_marginBottom="16dp"
                android:visibility="gone">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Blur Strength"
                        android:textColor="?attr/colorOnSurface"
                        android:layout_marginTop="4dp"
                        android:layout_marginBottom="4dp"
                        android:textStyle="bold"/>

                    <com.google.android.material.slider.Slider
                        android:id="@+id/sliderBlurStrength"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:valueFrom="0.0"
                        android:valueTo="400.0"
                        android:stepSize="10.0"
                        android:value="200.0"
                        android:layout_marginBottom="24dp"/>

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnUpdateBlur"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Update Blur Strength"
                        android:backgroundTint="@color/btn_update_selector"
                        android:textColor="@color/text_update_selector"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>


            <LinearLayout
                android:id="@+id/layoutColors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingTop="16dp"
                android:paddingBottom="16dp"
                android:layout_marginBottom="32dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sync System Colors"
                        android:textColor="@color/white"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Updates Material You colors on wallpaper change. Disable if buggy/laggy (in playlist mode especially)."
                        android:textColor="#B0B0B0"
                        android:textSize="12sp" />
                </LinearLayout>

                <com.google.android.material.materialswitch.MaterialSwitch
                    android:id="@+id/switchNotifyColors"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:thumbTint="@color/white"
                    android:trackTint="#505050" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAdvanceSettings"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/fine_tune"
                android:backgroundTint="@color/brand_primary"
                android:textColor="@color/brand_on_primary"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnRotationInterval"
                style="@style/Widget.Material3.Button"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Update Wallpaper Rotation Interval"
                android:backgroundTint="@color/btn_update_selector"
                android:textColor="@color/text_update_selector"/>
        </LinearLayout>

    </LinearLayout>
</ScrollView>